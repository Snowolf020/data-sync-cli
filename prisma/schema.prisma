datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

datasource sqlite {
  provider = "sqlite"
  url      = env("SQLITE_DATABASE_URL")
}

model Data {
  id       String   @id @default(cuid())
  name     String
  syncedAt DateTime @default(now())
  @@map(name: "data")
}

model Cache {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  expiresAt DateTime
  @@map(name: "cache")
}